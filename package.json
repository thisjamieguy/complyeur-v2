{
  "name": "complyeur",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "knip": "knip --dependencies -n",
    "knip:full": "knip -n",
    "shellcheck": "shellcheck scripts/claude-stop-hook.sh scripts/seed-test-accounts.sh load-testing/run-load-test.sh agent/scripts/*.sh",
    "changelog": "git log --oneline --no-merges $(git describe --tags --abbrev=0 2>/dev/null || git rev-list --max-parents=0 HEAD)..HEAD",
    "prepare": "husky",
    "db:types": "supabase gen types typescript --project-id sheqtawytsidyhzpzefk > types/database.ts",
    "test:endpoints": "echo 'Use the test page at /test-endpoints or install tsx: pnpm add -D tsx && pnpm tsx scripts/test-endpoints.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:compliance": "vitest run lib/compliance/__tests__",
    "test:unit": "vitest run lib/compliance/__tests__ __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:baseline": "playwright test e2e/public-smoke.spec.ts e2e/auth-smoke.spec.ts e2e/auth-navigation.spec.ts e2e/page-coverage.spec.ts e2e/import-happy-path.spec.ts",
    "test:e2e:import": "playwright test e2e/import-workflow.spec.ts",
    "test:e2e:dashboard": "playwright test e2e/dashboard-verification.spec.ts",
    "test:e2e:multi-user": "playwright test e2e/multi-user-isolation.spec.ts",
    "test:e2e:stress": "playwright test e2e/stress-test.spec.ts --timeout=300000",
    "test:e2e:calendar-performance": "playwright test e2e/performance/calendar-performance.spec.ts",
    "test:regression": "playwright test e2e/phase-regression.spec.ts",
    "test:regression:ui": "playwright test e2e/phase-regression.spec.ts --ui",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "test:report": "node scripts/generate-test-report.js",
    "billing:prices:sync": "tsx scripts/syncStripePrices.ts --mapping scripts/stripe-price-mapping.beta.template.json --interval both",
    "billing:prices:audit": "tsx scripts/auditStripePriceIds.ts",
    "billing:webhook:configure": "tsx scripts/configureStripeWebhook.ts",
    "billing:webhook:check": "tsx scripts/configureStripeWebhook.ts --check",
    "security:check": "pnpm audit",
    "stress-test": "tsx scripts/stress-test/index.ts",
    "stress-test:dry": "tsx scripts/stress-test/index.ts --dry-run",
    "email:test": "tsx scripts/send-test-email.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "16.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/nextjs": "^10.32.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.70.0",
    "resend": "^6.6.0",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "flatted": ">=3.4.2",
      "eslint>minimatch": ">=3.1.3",
      "glob>minimatch": ">=9.0.7",
      "@sentry/node>minimatch": ">=9.0.7",
      "picomatch": ">=4.0.4",
      "@commitlint/config-validator>ajv": ">=8.18.0"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "knip": "^6.2.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
