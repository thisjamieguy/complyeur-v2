# ComplyEUR — Environment Variable Template
#
# Copy this file to `.env.local` and fill in the values for local development:
#   cp .env.example .env.local
#
# Never commit `.env.local` or any file containing real secrets.
# See docs/ENVIRONMENTS.md for project references and docs/architecture/ENVIRONMENTS.md
# for the environment separation policy.
#
# Legend: [required] must be set for the app to run locally.
#         [optional] feature- or environment-specific; safe to leave unset locally.

# ---------------------------------------------------------------------------
# Supabase  (Dashboard → Settings → API)
# ---------------------------------------------------------------------------
# [required] Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# [required] Service role key bypasses RLS — server-side only, NEVER in frontend code.
SUPABASE_SERVICE_ROLE_KEY=
# [optional] Project ref + DB password, used by migration/type-gen tooling.
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# ---------------------------------------------------------------------------
# Application URL  (used for redirects, emails, canonical links)
# ---------------------------------------------------------------------------
# [required for full functionality] Local default is http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Stripe  (Dashboard → Developers → API keys / Webhooks)
# ---------------------------------------------------------------------------
# [required for billing flows] Use test-mode keys (sk_test_…, pk_test_…) locally.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# [optional] JSON map of price IDs and the public base URL for webhook config scripts.
STRIPE_PRICE_MAPPING_JSON=
STRIPE_WEBHOOK_BASE_URL=

# ---------------------------------------------------------------------------
# Email  (Resend)
# ---------------------------------------------------------------------------
# [required for email flows] Resend dashboard → API Keys.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
# [optional] Base URL for email assets (logos, etc.).
EMAIL_ASSET_BASE_URL=

# ---------------------------------------------------------------------------
# Rate limiting  (Upstash Redis)
# ---------------------------------------------------------------------------
# [optional locally / required in production] Fail-closed rate limiting backend.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Error tracking  (Sentry)
# ---------------------------------------------------------------------------
# [optional locally / required in production] DSN is public; auth token is build-only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# CAPTCHA  (Cloudflare Turnstile)
# ---------------------------------------------------------------------------
# [optional locally / required in production] Site key is public; secret is server-side.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Cron / scheduled jobs
# ---------------------------------------------------------------------------
# [required for cron endpoints] Generate with: openssl rand -hex 32
CRON_SECRET=

# ---------------------------------------------------------------------------
# Admin / ownership
# ---------------------------------------------------------------------------
# [optional] Comma-separated emails granted superadmin/site-owner access.
SUPERADMIN_EMAILS=
SITE_OWNER_EMAILS=

# ---------------------------------------------------------------------------
# Waitlist email encryption  (if the waitlist feature is enabled)
# ---------------------------------------------------------------------------
# [optional] Required only when collecting waitlist emails.
WAITLIST_EMAIL_ENCRYPTION_KEY=
WAITLIST_EMAIL_HASH_PEPPER=
WAITLIST_EMAIL_KEY_VERSION=

# ---------------------------------------------------------------------------
# Feature flags  (defaults are safe; override only when testing a feature)
# ---------------------------------------------------------------------------
# [optional] FEATURE_SAVED_JOBS defaults to disabled unless set to "true".
FEATURE_SAVED_JOBS=false
# [optional] Global interactive calendar switch. Leave false in production unless
# the feature should be available to every company with can_calendar.
ENABLE_INTERACTIVE_CALENDAR=false
# [optional] Comma/space/semicolon-separated account emails that can use the
# interactive calendar even when ENABLE_INTERACTIVE_CALENDAR=false.
INTERACTIVE_CALENDAR_ALLOWED_EMAILS=
# [optional] Maintenance mode banner / gate.
NEXT_PUBLIC_MAINTENANCE_MODE=false
# [optional] Vercel Speed Insights toggle.
NEXT_PUBLIC_ENABLE_SPEED_INSIGHTS=false

# ---------------------------------------------------------------------------
# Social handles  (public marketing links)
# ---------------------------------------------------------------------------
# [optional]
NEXT_PUBLIC_X_HANDLE=
NEXT_PUBLIC_TWITTER_HANDLE=

# ---------------------------------------------------------------------------
# Test / E2E only  (never set these in production)
# ---------------------------------------------------------------------------
# [optional] Used by Playwright/e2e harnesses to bypass MFA in controlled runs.
DISABLE_MFA_FOR_E2E=
MFA_BYPASS_CONTEXT=
TEST_EMAIL_TO=
TEST_URL=
